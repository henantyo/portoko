# Backend runs server-side Supabase operations (service role)
# Copy to backend/.env and fill values.

PORT=4000

# Supabase configuration (optional - for cloud sync)
SUPABASE_URL=https://gugmoxytczgvmoezrnyc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin authentication credentials
# Username default: admin
# Password default: admin123 (stored as bcrypt hash in admin-config.json)
# You can change the password via the Admin Dashboard "Settings" tab
ADMIN_USERNAME=admin

